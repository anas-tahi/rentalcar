# ─────────────────────────────────────────────────────────────
# DriveES — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────
# Get a free cluster at https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/rentalcar?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRE=7d

# ── PayPal (Sandbox) ──────────────────────────────────────────
# Get credentials at https://developer.paypal.com/dashboard/
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret

# ── Stripe (optional) ─────────────────────────────────────────
# Get a test key at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_placeholder

# ── Environment ───────────────────────────────────────────────
NODE_ENV=development
